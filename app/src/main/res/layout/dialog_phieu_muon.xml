<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minWidth="450dp"
    android:orientation="vertical"
    android:padding="35dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="THÔNG TIN PHIẾU MƯỢN"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/tvMaPM"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mã phiếu mượn: "
        android:textSize="18sp"
        android:layout_marginTop="10dp"/>

    <!-- Thành viên Label -->
    <LinearLayout
        android:id="@+id/layout_spThanhVien"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:id="@+id/tvThanhVienLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Thành viên:"
            android:textSize="18sp"
            android:textColor="@color/black"/>

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/arrow_down_float"
            android:contentDescription="Dropdown icon" />
    </LinearLayout>

    <Spinner
        android:id="@+id/spThanhVien"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="invisible" />

    <!-- Sách Label -->
    <LinearLayout
        android:id="@+id/layout_spSach"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:id="@+id/tvSachLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sách:"
            android:textSize="18sp"
            android:textColor="@color/black"/>

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/arrow_down_float"
            android:contentDescription="Dropdown icon" />
    </LinearLayout>

    <Spinner
        android:id="@+id/spSach"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="invisible" />

    <TextView
        android:id="@+id/tvTienThue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tiền thuê: 0"
        android:textSize="18sp"
        android:layout_marginTop="10dp"
        android:textColor="@color/black"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Số lượng mượn:"
            android:textSize="18sp"
            android:textColor="@color/black"/>

        <Button
            android:id="@+id/btnMinus"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="-"
            style="@style/Widget.MaterialComponents.Button.TextButton"/>

        <EditText
            android:id="@+id/edSoLuongMuon"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:inputType="number"
            android:text="1"
            android:textSize="18sp"
            android:background="@null"/>

        <Button
            android:id="@+id/btnPlus"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="+"
            style="@style/Widget.MaterialComponents.Button.TextButton"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ngày mượn: "
            android:textSize="18sp"
            android:textColor="@color/black"/>
        <TextView
            android:id="@+id/tvNgayMuon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2023-01-01"
            android:textSize="18sp"
            android:textColor="@android:color/holo_blue_dark"
            android:padding="5dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hạn trả: "
            android:textSize="18sp"
            android:textColor="@color/black"/>
        <TextView
            android:id="@+id/tvHanTra"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2023-01-01"
            android:textSize="18sp"
            android:textColor="@android:color/holo_blue_dark"
            android:padding="5dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvNgayTra"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ngày trả: Chưa trả"
        android:textSize="18sp"
        android:layout_marginTop="10dp"
        android:textColor="@color/black"/>

    <Button
        android:id="@+id/btnXacNhanTraSach"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Xác nhận trả sách"
        android:layout_marginTop="10dp"
        android:textAllCaps="false"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:visibility="gone"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilGhiChu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:hint="Ghi chú"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edGhiChu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:minLines="1"/>
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnCancel"
            style="@style/Widget.App.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Hủy"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="5dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Lưu"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginStart="5dp"/>
    </LinearLayout>

</LinearLayout>
