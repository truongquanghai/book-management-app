<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/imgDel"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTenSach"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên sách"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primaryColor"/>

            <TextView
                android:id="@+id/tvMaSach"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Mã sách: 01"
                android:textSize="13sp"
                android:textColor="#888888"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvGiaThue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giá thuê: 2000"
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:layout_marginEnd="15dp"/>

                <TextView
                    android:id="@+id/tvLoai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loại: Kinh tế"
                    android:textSize="14sp"
                    android:textColor="#555555"/>
            </LinearLayout>

        </LinearLayout>

        <ImageView
            android:id="@+id/imgDel"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#FF5252" />

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>